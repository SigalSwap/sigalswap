# OS cruft
.DS_Store

# Node
node_modules/

# Private working docs + Claude Code local state -- kept locally, never published
.claude/

# Aztec codegen cache
codegenCache.json

# Mutation-testing sandboxes
.stryker-tmp/

# Built site output (regenerated)
site/*/dist/

# Generated cost-model tables (regenerated from tools/twap/cost_model.py)
tools/twap/tables/

# Python bytecode cache
__pycache__/
*.pyc

# Fuzz corpora (regenerated by `nargo fuzz`)
corpus/

# Compiled / generated outputs (regenerated from source)
dist/
*.tsbuildinfo
packages/sdk/reports/
tools/mutation/reports/

# Vendored Aztec dep source -- local-only, reproducible by re-cloning the pinned Aztec tag
vendor/

# Compiled contract artifacts (regenerated by `aztec compile`)
**/target/

# Claude Code project instructions -- local dev guidance, not for the public repo
/CLAUDE.md

# Local environment
.env
.env.local
.env.*.local

# Compiled-artifact backups -- never ship
*.json.bak

# Fuzz counterexamples are regenerated on a failing run; they are not source
**/Prover-failing-*.toml

# SDK contract bindings (regenerated by `npm run codegen` from the compiled
# contract artifacts; see packages/sdk/README.md for the build steps)
packages/sdk/src/artifacts/

# Web app's fetched contract artifacts (compiled Aztec artifacts placed in during dev setup)
site/*/public/artifacts/
